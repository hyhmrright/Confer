{
  "name": "@confer/gateway",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "test": "bun test",
    "test:db:setup": "bun run scripts/setup-test-db.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "@confer/agent-runtime": "workspace:*",
    "@confer/identity": "workspace:*",
    "@confer/shared": "workspace:*",
    "argon2": "^0.41.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "jose": "^6.0.0",
    "minio": "^8.0.7",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pdf-parse": "^1.1.5",
    "drizzle-kit": "^0.30.0"
  }
}
